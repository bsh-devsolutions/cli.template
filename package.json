{
  "name": "@bsh/cli-starter",
  "version": "0.0.1",
  "description": "Starter template for BSH CLIs",
  "type": "module",
  "bin": {
    "cli-starter": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && npm run commands:tree",
    "watch": "tsup --watch",
    "cli": "tsx src/cli.ts",
    "commands:tree": "tsx scripts/commands-tree.ts",
    "test": "vitest run && npm run commands:tree",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "bsh",
    "cli",
    "typescript",
    "template"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
